{
    "hooks":  {
                  "SessionStart":  [
                                       {
                                           "matcher":  "",
                                           "hooks":  [
                                                         {
                                                             "type":  "command",
                                                             "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook session-start"
                                                         }
                                                     ]
                                       }
                                   ],
                  "PreToolUse":  [
                                     {
                                         "matcher":  "Edit|Write|MultiEdit",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook guard"
                                                       }
                                                   ]
                                     },
                                     {
                                         "matcher":  "Bash",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook guard-bash"
                                                       },
                                                       {
                                                           "type":  "command",
                                                           "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook gate"
                                                       }
                                                   ]
                                     }
                                 ],
                  "PostToolUse":  [
                                      {
                                          "matcher":  "Write|Edit|MultiEdit",
                                          "hooks":  [
                                                        {
                                                            "type":  "command",
                                                            "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook format"
                                                        },
                                                        {
                                                            "type":  "command",
                                                            "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook checkbox-guard"
                                                        },
                                                        {
                                                            "type":  "command",
                                                            "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook task-progress"
                                                        },
                                                        {
                                                            "type":  "command",
                                                            "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook artifact-validate"
                                                        }
                                                    ]
                                      },
                                      {
                                          "matcher":  "Read|Bash",
                                          "hooks":  [
                                                        {
                                                            "type":  "command",
                                                            "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook leak-guard"
                                                        }
                                                    ]
                                      }
                                  ],
                  "UserPromptExpansion":  [
                                              {
                                                  "matcher":  "code-review",
                                                  "hooks":  [
                                                                {
                                                                    "type":  "command",
                                                                    "command":  "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/bin/rein.exe hook inject"
                                                                }
                                                            ]
                                              }
                                          ]
              },
    "permissions":  {
                        "allow":  [
                                      "Bash(rein *)"
                                  ]
                    }
}
